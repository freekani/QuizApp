@page "/admin/questions"
@using QuizGame.Models
@using QuizGame.Services
@inject IQuizService QuizService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>問題管理ツール</h2>
        <button class="btn btn-primary" @onclick='() => NavigationManager.NavigateTo("/add-question")'>
            <span class="bi bi-plus-lg"></span> 新規作成
        </button>
    </div>

    @if (questions == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">読み込み中...</span>
            </div>
        </div>
    }
    else if (!questions.Any())
    {
        <div class="alert alert-info shadow-sm">登録されている問題がありません。</div>
    }
    else
    {
        <div class="table-responsive shadow card">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 5%">ID</th>
                        <th>問題内容</th>
                        <th style="width: 10%">選択肢数</th>
                        <th style="width: 15%">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in questions)
                    {
                        <tr>
                            <td>@q.Id</td>
                            <td>@q.Content</td>
                            <td><span class="badge bg-secondary rounded-pill">@q.Choices.Count</span></td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    @* ▼ 修正ボタンを追加 *@
                                    <button class="btn btn-outline-primary" 
                                            @onclick='() => NavigationManager.NavigateTo($"/admin/edit-question/{q.Id}")'>
                                        <span class="bi bi-pencil-fill"></span> 修正
                                    </button>
                                    <button class="btn btn-outline-danger" @onclick="() => DeleteQuestion(q)">
                                        <span class="bi bi-trash-fill"></span> 削除
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Question>? questions;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuestions();
    }

    private async Task LoadQuestions()
    {
        questions = await QuizService.GetQuizzesAsync();
    }

    private async Task DeleteQuestion(Question question)
    {
        // ▼ 削除前に確認ダイアログを表示
        var message = $"問題ID:{question.Id} 「{question.Content}」 を削除しますか？\n（纽付いている選択肢もすべて消去されます）";
        if (await JSRuntime.InvokeAsync<bool>("confirm", message))
        {
            await QuizService.DeleteQuestionAsync(question.Id);
            await LoadQuestions(); // リストを再読み込み
        }
    }
}